<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Form View to Modify it -->
        <record id="cd_custom_task_crm_form" model="ir.ui.view">
            <field name="name">cd_custom_task_crm_form</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//header" position="inside">
                    <button name="create_task" string="Crear Tarea" type="object"/>
                </xpath>

<!--                <xpath expr="//field[@name='phone']" position="after">-->
<!--                    <field name="task_ids" widget="many2many_tags" />-->
<!--                </xpath>-->

                <xpath expr="//notebook/page[@name='lead']" position="after">
                    <page name="associated_tasks" string="Tareas Asociadas">
                        <field name="task_ids"  options="{'no_create': True, 'no_create_edit': True, 'no_open': True}">  <!-- Para que solo se cree desde el botón.-->
                            <list string="Tareas" create="0" delete="0">
                                <field name="name"/>
                                <field name="user_ids"/>
                                <field name="tag_ids"/>
                                <field name="stage_id"/>


                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="cd_custom_task_crm_list" model="ir.ui.view">
            <field name="name">cd.custom.task.crm.list</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='contact_name']" position="after">
                    <field name="task_ids"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>