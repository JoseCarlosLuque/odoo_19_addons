<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Form View to Modify it -->
        <record id="cd_workshop_flows_purchase_form" model="ir.ui.view">
            <field name="name">cd.workshop.flows.purchase.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet/div[@name='button_box']" position="inside">
                    <button name="action_add_factory_boards"
                            type="object"
                            string="AÑADIR TABLEROS"
                            class="btn-success btn-sm rounded-pill"
                    />
                </xpath>

            </field>
        </record>

    </data>
</odoo>